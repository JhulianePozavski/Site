  .hero-photo { width: 100%; height: 100%; min-height: 520px; object-fit: cover; object-position: center top; display: block; }
  .hero-decor { position: absolute; bottom: 2.5rem; left: 1.5rem; background: var(--cream); border: 1px solid var(--line); border-radius: 1.2rem; padding: 1.1rem 1.6rem; display: flex; align-items: center; gap: 1rem; box-shadow: 0 8px 32px rgba(60,30,10,.07); opacity: 0; animation: fadeUp .9s 1s forwards; z-index: 2; }
