  .abord-desc { max-width: 620px; margin: 2.5rem auto 0; font-size: .95rem; font-weight: 300; color: rgba(250,248,243,.65); line-height: 1.9; }

  /* ATENDIMENTO */
  #atendimento { background: var(--warm); }
